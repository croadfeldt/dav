FROM python:3.11-slim

# Source provenance — populated by Ansible at build time via --build-arg.
ARG DAV_REPO_COMMIT=unknown
ARG DAV_REPO_DIRTY=unknown
LABEL org.opencontainers.image.title="dav-docs-mcp" \
      org.opencontainers.image.revision="${DAV_REPO_COMMIT}" \
      io.dav.repo.dirty="${DAV_REPO_DIRTY}"

WORKDIR /app

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY server.py .

EXPOSE 8080

ENTRYPOINT ["python", "server.py", "--transport", "sse", "--port", "8080"]
# --docs-path is set via deployment env/args
