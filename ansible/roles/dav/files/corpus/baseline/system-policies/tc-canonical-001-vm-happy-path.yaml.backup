uuid: tc-canonical-001
handle: test/standard/vm-provision-happy
version: "1.0.0"
generated_by: human

scenario:
  description: >
    Consumer requests a Compute.VirtualMachine in a standard profile deployment.
    Single tenant, no cross-tenant interaction, single eligible provider (KubeVirt).
    All system default policies. No failures. Validates the complete nine-step assembly
    process and full entity lifecycle through OPERATIONAL state.
  dimensions:
    lifecycle_phase: new_request
    resource_complexity: single_no_deps
    policy_complexity: system_defaults_only
    provider_landscape: single_eligible
    governance_context: single_tenant
    failure_mode: none
  profiles: standard
  references:
    - document: "00-foundations"
      section: "Section 0 — Runtime loop"
    - document: "06-assembly"
      section: "Section 6.9 — Nine-step assembly"
      system_policy: TEN-001
    - document: "08-entities"
      section: "Section 8.4 — Entity lifecycle"

inputs:
  intent_payload:
    resource_type: "Compute.VirtualMachine"
    fields:
      cpu:
        value: 4
        override: allow
      memory_gb:
        value: 16
        override: allow
      os_image:
        value: "rhel-9.4"
        override: allow
    tenant_uuid: "tenant-engineering-001"

  active_policies: []  # System defaults only — no custom policies

  active_layers:
    - uuid: "layer-platform-compute-defaults"
      domain: platform
      fields:
        cpu: { value: 2, override: allow, basis_for_value: "Platform default CPU" }
        memory_gb: { value: 8, override: allow, basis_for_value: "Platform default memory" }

  provider_registry:
    - uuid: "provider-kubevirt-001"
      type: service_provider
      capabilities: ["realize", "discover", "health"]
      resource_types: ["Compute.VirtualMachine"]
      sovereignty_zones: ["zone-us-east"]
      accreditations: ["standard-compute"]
      capacity:
        mode: provider_registration
        available_cpu: 100
        available_memory_gb: 512

  tenant_structure:
    uuid: "tenant-engineering-001"
    handle: "engineering"
    profile: standard
    enforcement: mandatory

expected_outcomes:
  pipeline_result: completed
  final_entity_state: OPERATIONAL
  state_transitions:
    - REQUESTED
    - PENDING
    - PROVISIONING
    - REALIZED
    - OPERATIONAL
  provenance_chain_valid: true
  security_checks_passed:
    - identity
    - authorization
    - accreditation
    - matrix
    - sovereignty
  audit_records_produced:
    - type: request_received
      granularity: mutation
    - type: assembly_completed
      granularity: mutation
    - type: placement_completed
      granularity: mutation
    - type: provider_dispatch
      granularity: mutation
    - type: realization_confirmed
      granularity: mutation
  placement_decision:
    provider_uuid: "provider-kubevirt-001"
    reason: "Single eligible provider after sovereignty and capability filters"

evaluation:
  p1_security:
    score: pass
    checks:
      - check: five_check_boundary_fired
        result: true
      - check: data_classification_honored
        result: true
      - check: provenance_on_all_modified_fields
        result: true
  p2_ease_of_use:
    score: pass
    checks:
      - check: consumer_path_achievable
        result: true
      - check: no_internal_knowledge_required
        result: true
  p3_extensibility:
    score: deferred
  p4_fit_for_purpose:
    score: pass
    checks:
      - check: full_lifecycle_reachable
        result: true
      - check: entity_in_operational_state
        result: true
