uuid: tc-canonical-002
handle: test/cross-profile/tenant-boundary-enforcement
version: "1.0.0"
generated_by: human

scenario:
  description: >
    Validates GRP-001 (every resource must belong to exactly one tenant_boundary group)
    and the profile-governed enforcement model. In minimal profile, tenancy is advisory —
    the request succeeds with a warning. In standard+ profiles, tenancy is mandatory —
    a request without a valid tenant_uuid is rejected by the GateKeeper.
    Cross-profile test validates P1: security property (tenancy) is PRESENT in all
    profiles; only enforcement strictness varies.
  dimensions:
    lifecycle_phase: new_request
    resource_complexity: single_no_deps
    policy_complexity: single_gatekeeper
    provider_landscape: single_eligible
    governance_context: single_tenant
    failure_mode: none
  profiles:
    - minimal
    - dev
    - standard
    - prod
    - fsi
    - sovereign
  references:
    - document: "15-universal-groups"
      section: "Section 10.3 — tenant_boundary"
      system_policy: GRP-001
    - document: "15-universal-groups"
      section: "Section 10.3 — profile-governed enforcement"
      system_policy: GRP-011
    - document: "00-design-priorities"
      section: "Priority 1 — Security"
      system_policy: DPO-001

inputs:
  intent_payload:
    resource_type: "Compute.VirtualMachine"
    fields:
      cpu: { value: 2, override: allow }
      memory_gb: { value: 8, override: allow }
    # Deliberately omitting tenant_uuid to test enforcement
    tenant_uuid: null

  active_policies:
    - uuid: "policy-grp-001-tenant-required"
      handle: "system/policy/grp-001"
      type: gatekeeper
      domain: system
      status: active
      match_conditions:
        resource_type: "*"
        event: "intent.created"
      output:
        action: deny
        reason: "GRP-001: Every resource must belong to exactly one tenant_boundary group"

  provider_registry:
    - uuid: "provider-kubevirt-001"
      type: service_provider
      capabilities: ["realize"]
      resource_types: ["Compute.VirtualMachine"]
      sovereignty_zones: ["zone-us-east"]

expected_outcomes:
  # Per-profile outcomes
  minimal:
    pipeline_result: completed
    # Advisory only — request proceeds with warning
    audit_records_produced:
      - type: tenancy_warning
        urgency: medium
    security_checks_passed:
      - identity
      - authorization
      - accreditation
      - matrix
      - sovereignty

  dev:
    pipeline_result: completed
    # Warn only — same as minimal but audit recorded
    audit_records_produced:
      - type: tenancy_warning
        urgency: medium

  standard:
    pipeline_result: rejected
    # Blocking — GateKeeper denies
    policies_fired:
      - uuid: "policy-grp-001-tenant-required"
        type: gatekeeper
        output: deny
    audit_records_produced:
      - type: gatekeeper_deny
        urgency: high

  prod:
    pipeline_result: rejected
    policies_fired:
      - uuid: "policy-grp-001-tenant-required"
        type: gatekeeper
        output: deny

  fsi:
    pipeline_result: rejected
    # Hard tenancy — strictest enforcement
    policies_fired:
      - uuid: "policy-grp-001-tenant-required"
        type: gatekeeper
        output: deny

  sovereign:
    pipeline_result: rejected
    policies_fired:
      - uuid: "policy-grp-001-tenant-required"
        type: gatekeeper
        output: deny

evaluation:
  p1_security:
    score: pass
    checks:
      - check: tenancy_check_present_all_profiles
        result: true
      - check: enforcement_scales_with_profile
        result: true
      - check: security_property_never_absent
        result: true
  p2_ease_of_use:
    score: pass
    checks:
      - check: rejection_message_actionable
        result: true
      - check: consumer_knows_what_to_fix
        result: true
  p3_extensibility:
    score: deferred
  p4_fit_for_purpose:
    score: pass
    checks:
      - check: invalid_request_correctly_rejected
        result: true
