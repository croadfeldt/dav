---
# Tekton Pipeline: full DAV stage 2 corpus run.
#
# The pipeline:
#
#   1. Clones the consumer's spec repo (architecture docs)
#   2. Clones the consumer's corpus repo (use cases + dav-version.yaml)
#   3. Runs dav-run-corpus across the entire corpus
#
# All three steps share one workspace, with the spec and corpus going
# into separate subdirectories. This keeps the pipeline simple (one
# workspace, no inter-step PVC juggling) while preserving the two-repo
# architecture for the consumer side.
#
# The pipeline finishes when run-corpus finishes — successfully if all
# UCs analyzed, failed if --halt-on-error fired on a UC failure or the
# runner itself crashed. Per-UC failures with continue-on-error are
# reported in the run summary, not as pipeline failures.

apiVersion: tekton.dev/v1
kind: Pipeline
metadata:
  name: dav-stage2
  namespace: {{ dav_namespace }}
  labels:
    app.kubernetes.io/part-of: dav
spec:
  description: |
    Run DAV stage 2 across the consumer's full UC corpus.

  params:
    # Consumer source repos (defaults from group_vars/all/vars.yaml)
    - name: consumer-spec-repo-url
      type: string
      default: "{{ consumer_spec_repo_url }}"
    - name: consumer-spec-repo-branch
      type: string
      default: "{{ consumer_spec_repo_branch }}"
    - name: consumer-corpus-repo-url
      type: string
      default: "{{ consumer_corpus_repo_url }}"
    - name: consumer-corpus-repo-branch
      type: string
      default: "{{ consumer_corpus_repo_branch }}"

    # Where to put the cloned content within the workspace
    - name: spec-subdir
      type: string
      default: "spec"
    - name: corpus-subdir
      type: string
      default: "corpus"

    # Path to the use-case directory inside the corpus repo
    # (DCM convention: use-cases/ at the corpus repo root)
    - name: corpus-uc-subpath
      type: string
      default: "use-cases"

    # Run-corpus settings
    - name: mode
      type: string
      default: "verification"
    - name: sample-count
      type: string
      default: ""
    - name: halt-on-error
      type: string
      default: "false"

    # Inference + MCP
    - name: inference-endpoint
      type: string
      default: "{{ inference_primary_endpoint }}"
    - name: inference-model
      type: string
      default: "{{ inference_primary_model }}"
    - name: mcp-url
      type: string
      default: "http://dav-docs-mcp.{{ dav_namespace }}.svc:8080"

    # Optional consumer profile override
    - name: consumer-profile-path
      type: string
      default: ""

  workspaces:
    - name: shared-data
      description: |
        Shared workspace. Two upstream sync tasks populate <spec-subdir>
        and <corpus-subdir>; the run-corpus task reads from both and
        writes results to results/<run-id>/.

  tasks:
    # 1. Clean stale workspace state before sync.
    #    The dav-workspace PVC persists across PipelineRuns, so prior-run
    #    spec/ and corpus/ directories accumulate on disk. The git-sync
    #    task can recover from stale state (commit 221b30c) and from
    #    force-pushed upstream (commit abd46ea), but both add latency
    #    and cognitive load. Wiping spec/ and corpus/ at pipeline start
    #    forces a clean fresh-clone every run.
    #
    #    NOT wiped: results/ — operators need previous runs' analyses
    #    until they're externally archived. Result retention is a
    #    separate concern from workspace cleanup.
    - name: cleanup-workspace
      timeout: "5m"
      taskSpec:
        workspaces:
          - name: source
        steps:
          - name: wipe-sync-targets
            image: registry.access.redhat.com/ubi9/ubi-minimal
            script: |
              #!/bin/sh
              set -e
              cd "$(workspaces.source.path)"
              echo "Workspace contents before cleanup:"
              ls -la . || true
              echo ""
              for d in spec corpus; do
                if [ -e "$d" ]; then
                  echo "Removing existing $d/"
                  rm -rf "$d"
                fi
              done
              echo ""
              echo "Workspace contents after cleanup:"
              ls -la .
      workspaces:
        - name: source
          workspace: shared-data

    # 2. Clone the consumer's spec repo into <spec-subdir>
    - name: sync-spec
      timeout: "10m"
      runAfter:
        - cleanup-workspace
      taskRef:
        name: dav-git-sync
      workspaces:
        - name: source
          workspace: shared-data
      params:
        - name: repo-url
          value: $(params.consumer-spec-repo-url)
        - name: repo-branch
          value: $(params.consumer-spec-repo-branch)
        - name: target-subdir
          value: $(params.spec-subdir)

    # 3. Clone the consumer's corpus repo into <corpus-subdir>
    #    (runs in parallel with sync-spec since both are read-only clones)
    - name: sync-corpus
      timeout: "10m"
      runAfter:
        - cleanup-workspace
      taskRef:
        name: dav-git-sync
      workspaces:
        - name: source
          workspace: shared-data
      params:
        - name: repo-url
          value: $(params.consumer-corpus-repo-url)
        - name: repo-branch
          value: $(params.consumer-corpus-repo-branch)
        - name: target-subdir
          value: $(params.corpus-subdir)

    # 4. Run DAV stage 2 across the corpus
    #    Per-UC wall time at LLM inference is highly variable depending on
    #    UC complexity, ensemble sample count, model size, and inference
    #    backend. Allow up to 24h for a full corpus run (~10-30 UCs at
    #    verification-mode N=3 against 32B+ models).
    - name: run-corpus
      timeout: "24h"
      runAfter:
        - sync-spec
        - sync-corpus
      taskRef:
        name: dav-run-corpus
      workspaces:
        - name: source
          workspace: shared-data
      params:
        - name: corpus-subdir
          value: "$(params.corpus-subdir)/$(params.corpus-uc-subpath)"
        - name: spec-subdir
          value: $(params.spec-subdir)
        - name: output-subdir
          value: "results"
        - name: mode
          value: $(params.mode)
        - name: sample-count
          value: $(params.sample-count)
        - name: halt-on-error
          value: $(params.halt-on-error)
        - name: inference-endpoint
          value: $(params.inference-endpoint)
        - name: inference-model
          value: $(params.inference-model)
        - name: mcp-url
          value: $(params.mcp-url)
        - name: consumer-profile-path
          value: $(params.consumer-profile-path)
