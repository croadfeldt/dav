---
# DAV — Site-specific configuration template
#
# This file is committed to the repo as a template. To use:
#   1. cp vars.local.yaml.example vars.local.yaml
#   2. Edit vars.local.yaml with your site values
#   3. vars.local.yaml is gitignored and auto-loaded by Ansible
#      because it lives in group_vars/all/.
#
# Required values must be set for the playbook to run successfully.
# Replace the example values with your actual infrastructure details.
# inference_fallback_endpoint is optional (see Tier 2 section below).

# --- Inference Tier 1 (primary) ---
# OpenAI-compatible /v1 endpoint URL of your primary inference server.
# Example: home lab GPU host running llama.cpp or vLLM.
# The endpoint is reached from cluster pods, so it must be reachable
# from the cluster's worker subnet (LAN access usually sufficient).
inference_primary_endpoint: "http://inference.example.local:8000/v1"

# --- Inference Tier 2 (fallback) — OPTIONAL ---
# If set, the engine retries against this endpoint when the primary
# returns an error. Leave unset to disable failover (the primary
# becomes the sole inference path).
#
# To deploy the bundled in-cluster vLLM as a fallback, run:
#   ansible-playbook ansible/playbook.yaml --tags vllm
# and uncomment the line below to point the engine at it. Without
# --tags vllm the playbook does NOT deploy vllm-tier3.
#
# inference_fallback_endpoint: "http://vllm-tier3.{{ dav_namespace }}.svc:8000/v1"

# Optional: in-cluster service DNS of an existing R9700 vLLM deployment
# in a different namespace. Used only if you have a separate vllm-r9700
# service running and want validate.yaml to probe it.
# Leave commented out if not applicable.
# vllm_r9700_endpoint: "http://vllm-r9700.vllm-r9700.svc:8000/v1"

# --- Consumer spec repo (architecture docs served by MCP) ---
# Holds your consumer's architectural specification. DAV's MCP server
# clones this repo and exposes the docs to the Stage 2 analyzer.
consumer_spec_repo_url: "https://github.com/your-org/your-spec-repo.git"

# --- Consumer corpus repo (use cases + baselines) ---
# Holds your consumer's use cases (test scenarios DAV evaluates) and
# the analysis baselines used by the regression comparator.
consumer_corpus_repo_url: "https://github.com/your-org/your-corpus-repo.git"

# --- Webhook Route ---
# Hostname for the GitHub webhook receiver (Tekton EventListener route).
# Must be a valid DNS name on your cluster's apps domain.
# Example for OpenShift: dav-webhook.apps.<cluster>.<basedomain>
dav_webhook_hostname: "dav-webhook.apps.your-cluster.example.com"

# --- Review Console ---
# Hostname for the review console UI (OAuth-gated).
# Example for OpenShift: dav-review.apps.<cluster>.<basedomain>
review_console_hostname: "dav-review.apps.your-cluster.example.com"
